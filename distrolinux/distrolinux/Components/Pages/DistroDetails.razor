@page "/distro/{distroId:guid}"

@using Distrolinux.Models
@rendermode InteractiveServer



@inject NavigationManager NavigationManager

<PageTitle>Detalhes da Distro</PageTitle>

<Header />

@if (isLoading)
{
    <p>Carregando...</p>
}
else if (errorMessage != null)
{
    <p class="text-danger">Erro: @errorMessage</p>
}
else if (distro != null)
{
    <div class="container" style="padding: 20px;">

      
        <div style="border: 1px solid #ccc; padding: 20px;">
            <h2>@distro.Nome</h2>
            <p>@distro.Descricao</p>
            <img width="300px" src="@distro.ImageUrl" alt="@distro.Nome" />
            <br><br>
            <p><strong>ISO:</strong> <a href="@distro.Iso" target="_blank">Download</a></p>
           
        </div>

        <br><br>
        <button class="btn btn-secondary mb-3" @onclick="GoHome">← Voltar</button>
    </div>
}

@code {
    [Parameter]
    public Guid distroId { get; set; }

    private DistroModel? distro;
    private string? errorMessage;
    private bool isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            using var client = new HttpClient();
            client.DefaultRequestHeaders.Add("Accept", "application/json");
            distro = await client.GetFromJsonAsync<DistroModel>($"http://localhost:5130/api/Distro/{distroId}");
            if (distro == null)
                errorMessage = "Distro não encontrada.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}