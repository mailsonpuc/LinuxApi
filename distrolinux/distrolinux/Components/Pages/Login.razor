@page "/login"
@using Distrolinux.Models
@using System.Net.Http.Json
@rendermode InteractiveServer
@inject HttpClient Http

<Header />



<div class="container">
    <h3>Login</h3>
    
    <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="form-group">
            <label for="email">Email</label>
            <InputText id="email" @bind-Value="loginModel.Email" class="form-control" />
        </div>

        <div class="form-group">
            <label for="password">Senha</label>
            <InputText id="password" @bind-Value="loginModel.Password" type="password" class="form-control" />
        </div>

        <div class="form-group">
            <label for="confirmPassword">Confirmar Senha</label>
            <InputText id="confirmPassword" @bind-Value="loginModel.ConfirmPassword" type="password"
                       class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Login</button>
    </EditForm>
</div>

<p>@message</p>

@code {
    private LoginModel loginModel = new LoginModel();
    private string message = "";

    private async Task HandleLogin()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5130/api/Token/login", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var userToken = await response.Content.ReadFromJsonAsync<UserToken>();
                // Aqui você pode armazenar o token, por exemplo, em localStorage ou em um serviço de autenticação
                message = $"Login bem-sucedido! Token: {userToken?.Token}";
            }
            else
            {
                message = "Erro no login: " + await response.Content.ReadAsStringAsync();
            }
        }
        catch (Exception ex)
        {
            message = "Erro: " + ex.Message;
        }
    }
}