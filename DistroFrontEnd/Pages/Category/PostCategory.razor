@page "/Postcategory"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Criar Nova Categoria</h3>

<hr />

<div class="row">
    <div class="col-md-4">
        <div class="form-group mb-3">
            <label for="Name" class="control-label">Nome da Categoria</label>
            <input id="Name" class="form-control" @bind="category.Name" />
        </div>
        <div class="form-group">
            <button type="button" class="btn btn-primary" @onclick="SaveCategory">Salvar</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
        </div>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private CategoryCreateDto category = new CategoryCreateDto();
    private string? errorMessage;

    private async Task SaveCategory()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(category.Name))
        {
            errorMessage = "O nome da categoria é obrigatório.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5130/api/Category", category);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/Getcategory");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Erro ao salvar: {response.StatusCode} - {error}";
            }
        }
        
        catch (Exception ex)
        {
            errorMessage = $"Ocorreu um erro: {ex.Message}";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/Getcategory");
    }

    public class CategoryCreateDto
    {
        public string? Name { get; set; }
    }
}
