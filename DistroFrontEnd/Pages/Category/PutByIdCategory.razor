@page "/PutByIdCategory"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Atualizar Categoria</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <label>Buscar por ID para editar:</label>
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Digite o ID..." @bind="searchId" />
            <button class="btn btn-primary" type="button" @onclick="FetchCategory">Buscar</button>
        </div>
    </div>
</div>

<hr />

@if (isLoading)
{
    <p><em>Carregando...</em></p>
}
else if (categoryToEdit != null)
{
    <div class="row">
        <div class="col-md-4">
            <div class="form-group mb-3">
                <label>ID:</label>
                <input class="form-control" value="@categoryToEdit.CategoryId" disabled />
            </div>
            <div class="form-group mb-3">
                <label for="Name">Novo Nome:</label>
                <input id="Name" class="form-control" @bind="categoryToEdit.Name" />
            </div>
            <div class="form-group">
                <button type="button" class="btn btn-success" @onclick="UpdateCategory">Atualizar</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
            </div>
        </div>
    </div>
}
else if (notFound)
{
    <div class="alert alert-warning">
        Nenhuma categoria encontrada com o ID "@searchId".
    </div>
}

@if (statusMessage != null)
{
    <div class="alert @statusClass mt-3">
        @statusMessage
    </div>
}

@code {
    private string? searchId;
    private CategoryDto? categoryToEdit;
    private bool isLoading = false;
    private bool notFound = false;
    private string? statusMessage;
    private string statusClass = "alert-info";

    private async Task FetchCategory()
    {
        if (string.IsNullOrWhiteSpace(searchId))
        {
            statusMessage = "Por favor, informe um ID.";
            statusClass = "alert-warning";
            categoryToEdit = null;
            return;
        }

        isLoading = true;
        statusMessage = null;
        notFound = false;
        categoryToEdit = null;

        try
        {
            var response = await Http.GetAsync($"http://localhost:5130/api/Category/{searchId}");

            if (response.IsSuccessStatusCode)
            {
                categoryToEdit = await response.Content.ReadFromJsonAsync<CategoryDto>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                notFound = true;
            }
            else
            {
                statusMessage = $"Erro na busca: {response.StatusCode}";
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Ocorreu um erro: {ex.Message}";
            statusClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateCategory()
    {
        if (categoryToEdit == null || string.IsNullOrWhiteSpace(categoryToEdit.Name))
        {
            statusMessage = "O nome não pode estar vazio.";
            statusClass = "alert-warning";
            return;
        }

        try
        {
            var response = await Http.PutAsJsonAsync($"http://localhost:5130/api/Category/{categoryToEdit.CategoryId}", categoryToEdit);

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Categoria atualizada com sucesso!";
                statusClass = "alert-success";
                // Opcional: Redirecionar após alguns segundos ou manter na página
                // Navigation.NavigateTo("/Getcategory");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                statusMessage = $"Erro ao atualizar: {response.StatusCode} - {error}";
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro: {ex.Message}";
            statusClass = "alert-danger";
        }
    }

    private void Cancel()
    {
        categoryToEdit = null;
        searchId = null;
        statusMessage = null;
    }

    public class CategoryDto
    {
        public string? CategoryId { get; set; }
        public string? Name { get; set; }
    }
}
