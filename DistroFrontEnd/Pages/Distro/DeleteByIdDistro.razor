@page "/DeleteByIdDistro"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Excluir Distribuição</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <label>Buscar por ID para excluir:</label>
        <div class="input-group">
            <input type="text" class="form-control" placeholder="Digite o ID..." @bind="searchId" />
            <button class="btn btn-primary" type="button" @onclick="FetchDistro">Buscar</button>
        </div>
    </div>
</div>

<hr />

@if (isLoading)
{
    <p><em>Carregando...</em></p>
}
else if (distroToDelete != null)
{
    <div class="alert alert-warning shadow-sm">
        <h5>Confirmar Exclusão</h5>
        <p>Tem certeza que deseja excluir a distribuição abaixo?</p>
        <hr />
        <div class="d-flex align-items-center">
            <img src="@distroToDelete.ImageUrl" style="width: 100px; height: 100px; object-fit: cover; margin-right: 20px;" class="rounded" alt="@distroToDelete.Nome" />
            <div>
                <p><strong>Nome:</strong> @distroToDelete.Nome</p>
                <p><strong>ID:</strong> @distroToDelete.DistroId</p>
            </div>
        </div>
        
        <div class="mt-3">
            <button type="button" class="btn btn-danger" @onclick="DeleteDistro">Confirmar Exclusão</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
        </div>
    </div>
}
else if (notFound)
{
    <div class="alert alert-warning">
        Nenhuma distribuição encontrada com o ID "@searchId".
    </div>
}

@if (statusMessage != null)
{
    <div class="alert @statusClass mt-3">
        @statusMessage
    </div>
}

@code {
    private string? searchId;
    private DistroDto? distroToDelete;
    private bool isLoading = false;
    private bool notFound = false;
    private string? statusMessage;
    private string statusClass = "alert-info";

    private async Task FetchDistro()
    {
        if (string.IsNullOrWhiteSpace(searchId))
        {
            statusMessage = "Por favor, informe um ID.";
            statusClass = "alert-warning";
            distroToDelete = null;
            return;
        }

        isLoading = true;
        statusMessage = null;
        notFound = false;
        distroToDelete = null;

        try
        {
            var response = await Http.GetAsync($"http://localhost:5130/api/Distro/{searchId}");

            if (response.IsSuccessStatusCode)
            {
                distroToDelete = await response.Content.ReadFromJsonAsync<DistroDto>();
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                notFound = true;
            }
            else
            {
                statusMessage = $"Erro na busca: {response.StatusCode}";
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Ocorreu um erro: {ex.Message}";
            statusClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteDistro()
    {
        if (distroToDelete == null) return;

        try
        {
            var response = await Http.DeleteAsync($"http://localhost:5130/api/Distro/{distroToDelete.DistroId}");

            if (response.IsSuccessStatusCode)
            {
                statusMessage = "Distribuição excluída com sucesso!";
                statusClass = "alert-success";
                distroToDelete = null;
                searchId = null;
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                statusMessage = $"Erro ao excluir: {response.StatusCode} - {error}";
                statusClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            statusMessage = $"Erro: {ex.Message}";
            statusClass = "alert-danger";
        }
    }

    private void Cancel()
    {
        distroToDelete = null;
        searchId = null;
        statusMessage = null;
    }

    public class DistroDto
    {
        public string? DistroId { get; set; }
        public string? ImageUrl { get; set; }
        public string? Nome { get; set; }
        public string? Descricao { get; set; }
        public string? Iso { get; set; }
        public string? CategoryId { get; set; }
    }
}
