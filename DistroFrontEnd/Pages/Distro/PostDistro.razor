@page "/Postdistro"
@inject HttpClient Http
@inject NavigationManager Navigation

<h3>Criar Nova Distribuição</h3>

<hr />

<div class="row">
    <div class="col-md-6">
        <div class="form-group mb-3">
            <label for="Nome" class="form-label">Nome</label>
            <input id="Nome" class="form-control" @bind="distro.Nome" />
        </div>
        <div class="form-group mb-3">
            <label for="Descricao" class="form-label">Descrição</label>
            <textarea id="Descricao" class="form-control" @bind="distro.Descricao"></textarea>
        </div>
        <div class="form-group mb-3">
            <label for="ImageUrl" class="form-label">URL da Imagem</label>
            <input id="ImageUrl" class="form-control" @bind="distro.ImageUrl" />
        </div>
        <div class="form-group mb-3">
            <label for="Iso" class="form-label">ISO</label>
            <input id="Iso" class="form-control" @bind="distro.Iso" />
        </div>
        <div class="form-group mb-3">
            <label for="CategoryId" class="form-label">ID da Categoria</label>
            <select id="CategoryId" class="form-select" @bind="distro.CategoryId">
                <option value="">Selecione uma categoria...</option>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.CategoryId">@cat.Name</option>
                    }
                }
            </select>
        </div>
        <div class="form-group">
            <button type="button" class="btn btn-primary" @onclick="SaveDistro">Salvar</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancelar</button>
        </div>
    </div>
</div>

@if (errorMessage != null)
{
    <div class="alert alert-danger mt-3">
        @errorMessage
    </div>
}

@code {
    private DistroCreateDto distro = new DistroCreateDto();
    private CategoryDto[]? categories;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await Http.GetFromJsonAsync<CategoryDto[]>("http://localhost:5130/api/Category");
        }
        catch (Exception ex)
        {
            errorMessage = $"Erro ao carregar categorias: {ex.Message}";
        }
    }

    private async Task SaveDistro()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(distro.Nome))
        {
            errorMessage = "O nome é obrigatório.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("http://localhost:5130/api/Distro", distro);

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/Getdistros");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                errorMessage = $"Erro ao salvar: {response.StatusCode} - {error}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Ocorreu um erro: {ex.Message}";
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/Getdistros");
    }

    public class DistroCreateDto
    {
        public string? ImageUrl { get; set; }
        public string? Nome { get; set; }
        public string? Descricao { get; set; }
        public string? Iso { get; set; }
        public string? CategoryId { get; set; }
    }

    public class CategoryDto
    {
        public string? CategoryId { get; set; }
        public string? Name { get; set; }
    }
}
